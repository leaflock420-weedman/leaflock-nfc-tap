<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌿 LeafLock NFC Tap"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Paradise pop-up · stickers · real Tap to Pay"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <!-- REAL phone-as-terminal (SoftPOS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 PHONE = TAP TO PAY TERMINAL"
                android:textColor="@color/green"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Customer taps their debit/credit card or phone on YOUR phone.\nThis needs a licensed app (bank rules). Our app cannot charge cards by itself."
                android:textColor="@color/text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/tapToPayStripeButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Open Stripe Dashboard (Tap to Pay AU)"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tapToPaySquareButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/green_dark"
                android:text="Open Square (Tap to Pay)"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tapToPayPaypalPosButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="PayPal POS app (if available in AU)"
                android:textAllCaps="false"
                android:textColor="@color/text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Australia: Stripe Tap to Pay + eftpos works on compatible Android. Sign up → install app → take payment → customer taps card on back of phone."
                android:textColor="@color/amber"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/panel"
            android:padding="14dp"
            android:text="Ready"
            android:textColor="@color/green"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="1) Pick a product"
            android:textColor="@color/muted"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/productSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@color/panel"
            android:padding="8dp" />

        <TextView
            android:id="@+id/productDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="2) Or custom amount (AUD)"
            android:textColor="@color/muted"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Custom amount e.g. 45.00"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="3) Link mode"
            android:textColor="@color/muted"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <RadioGroup
            android:id="@+id/modeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/modePos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Open LeafLock POS (recommended)"
                android:textColor="@color/text" />

            <RadioButton
                android:id="@+id/modePayPalMe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open PayPal.me (fallback)"
                android:textColor="@color/text" />
        </RadioGroup>

        <TextView
            android:id="@+id/linkPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/panel"
            android:padding="12dp"
            android:textIsSelectable="true"
            android:textColor="@color/amber"
            android:textSize="12sp"
            android:text="Link preview…" />

        <Button
            android:id="@+id/openLinkButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Open payment link now"
            android:textAllCaps="false"
            android:textStyle="bold" />

        <Button
            android:id="@+id/writeTagButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/green_dark"
            android:text="Write this link to NFC tag"
            android:textAllCaps="false"
            android:textStyle="bold" />

        <Button
            android:id="@+id/listenButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Start NFC listen (read tags)"
            android:textAllCaps="false"
            android:textColor="@color/text" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/anyTapSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Any NFC tap opens payment link (card = button only, not a card charge)"
            android:textColor="@color/text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Debit cards cannot be “read” for products. Use blank NTAG stickers. Customer taps sticker → browser → PayPal/POS."
            android:textColor="@color/amber"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Staff tip: write tags once (family, all4, two…). At the stand, open POS on the phone or let customers tap stickers."
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
