<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 LeafLock Tap to Pay"
                android:textColor="@color/text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Customer taps their debit/credit card or wallet on THIS phone"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/panel"
                android:minHeight="96dp"
                android:padding="14dp"
                android:text="Starting…"
                android:textColor="@color/green"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="PRODUCT"
                android:textAllCaps="true"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/productSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@color/panel"
                android:padding="8dp" />

            <TextView
                android:id="@+id/detailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="AMOUNT (AUD)"
                android:textAllCaps="true"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@color/panel"
                android:hint="80.00"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/noteInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@color/panel"
                android:hint="Optional note"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted" />

            <Button
                android:id="@+id/connectButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="Reconnect phone terminal"
                android:textAllCaps="false"
                android:textColor="@color/text" />

            <Button
                android:id="@+id/chargeButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:text="CHARGE — customer taps card"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/backStickersButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="NFC stickers / PayPal.me tools →"
                android:textAllCaps="false"
                android:textColor="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Requires Stripe (AU) + STRIPE_SECRET_KEY on Render. Phone: Android 13+, NFC, not rooted."
                android:textColor="@color/amber"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

    <!-- PAID overlay -->
    <LinearLayout
        android:id="@+id/paidOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#052E16"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="@color/green"
            android:textSize="72sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="PAID — HAND OVER PRODUCT"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/paidAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/green"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/paidId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/newSaleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="New sale"
            android:textAllCaps="false"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
